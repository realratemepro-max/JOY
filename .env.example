# Anthropic API Key for AI Bio Generation
# Get your API key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here

# Google Maps API Key for Places Autocomplete & Maps
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable: Places API, Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Cloud Function URL for Google Reviews Import
# Production: https://us-central1-YOUR-PROJECT-ID.cloudfunctions.net/getGooglePlaceReviews
# Development: http://localhost:5001/YOUR-PROJECT-ID/us-central1/getGooglePlaceReviews
VITE_CLOUD_FUNCTION_URL=https://us-central1-realrateme-app.cloudfunctions.net/getGooglePlaceReviews

# Google OAuth Credentials for Google My Business Integration
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorized redirect URIs:
#    - Development: http://localhost:5173/auth/google/callback
#    - Production: https://yourdomain.com/auth/google/callback
# 4. Enable: Google Business Profile API (https://console.cloud.google.com/apis/library/mybusinessbusinessinformation.googleapis.com)
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
VITE_GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
