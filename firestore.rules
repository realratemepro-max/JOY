rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ============================================
    // SITE CONFIGURATION
    // ============================================

    // Site config - public read, admin write
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services (yoga classes/packages) - public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Testimonials - public read, admin write
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================
    // CRM / CLIENTS
    // ============================================

    // Clients - admin only
    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }

    // Bookings - admin only
    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
    }

    // ============================================
    // USERS & AUTH
    // ============================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if isAdmin();
    }

    // ============================================
    // PAYMENT SYSTEM (EuPago)
    // ============================================

    // Payments collection
    match /payments/{paymentId} {
      // Users can read their own payments, admins can read all
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Authenticated users can create payments
      allow create: if isAuthenticated();
      // Only Cloud Functions update payments (webhook)
      allow update: if false;
      allow delete: if false;
    }

    // Subscriptions
    match /subscriptions/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isAdmin()
      );
      allow write: if false;
    }

    // Pricing plans
    match /pricing/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo codes
    match /promoCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo code redemptions
    match /promoCodeRedemptions/{redemptionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create, update, delete: if false;
    }

    // Email queue (for Cloud Functions)
    match /emails/{emailId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ============================================
    // DEFAULT DENY
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
