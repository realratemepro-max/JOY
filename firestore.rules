rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // PUBLIC: Site content (read-only)
    // ============================================
    match /siteConfig/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /locations/{id} { allow read: if true; allow write: if isAdmin(); }
    match /plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /pricing/{planId} { allow read: if true; allow write: if isAdmin(); }
    match /promoCodes/{id} { allow read: if true; allow write: if isAdmin(); }

    // Legacy services (read-only, deprecated)
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }

    // ============================================
    // USERS & AUTH
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if isAdmin();
    }

    // Legacy clients (admin only)
    match /clients/{id} { allow read, write: if isAdmin(); }

    // ============================================
    // SUBSCRIPTIONS
    // ============================================
    match /subscriptions/{id} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
      // Cloud Functions bypass rules via Admin SDK
    }

    // ============================================
    // SESSIONS
    // ============================================
    match /sessions/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // BOOKINGS (legacy + new)
    // ============================================
    match /bookings/{id} { allow read, write: if isAdmin(); }

    // ============================================
    // PAYMENTS (EuPago)
    // ============================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /promoCodeRedemptions/{id} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    match /emails/{id} { allow read: if isAdmin(); allow write: if false; }

    // ============================================
    // EVENTS (V2)
    // ============================================
    match /events/{id} { allow read: if true; allow write: if isAdmin(); }

    // CLIENT RESOURCES (V2)
    match /clientResources/{id} { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // ============================================
    // DEFAULT DENY
    // ============================================
    match /{document=**} { allow read, write: if false; }
  }
}
