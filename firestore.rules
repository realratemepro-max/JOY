rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own document (needed for admin check), admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Users can update their own document, admins can update any
      allow update: if isOwner(userId) || isAdmin();
      // Only authenticated users can create their own document
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Only admins can delete user documents
      allow delete: if isAdmin();
    }

    // Professionals collection
    match /professionals/{professionalId} {
      allow read: if true; // Public profiles
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Places collection
    match /places/{placeId} {
      allow read: if true; // Public
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        // Allow updates if user owns/created/claimed the place
        resource.data.ownerId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.claimedBy == request.auth.uid ||
        // Allow updates for unclaimed places (for professional count updates)
        resource.data.isClaimed == false ||
        isAdmin()
      );
      allow delete: if isAuthenticated() &&
        (resource.data.ownerId == request.auth.uid ||
         resource.data.createdBy == request.auth.uid ||
         resource.data.claimedBy == request.auth.uid ||
         isAdmin());
    }

    // Place owners collection (LEGACY - backward compatibility)
    match /placeOwners/{ownerId} {
      allow read: if isOwner(ownerId) || isAdmin();
      allow write: if isOwner(ownerId) || isAdmin();
    }

    // Place claims collection
    match /placeClaims/{claimId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // Feedbacks collection
    match /feedbacks/{feedbackId} {
      allow read: if true; // Public reviews
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        resource.data.reviewerId == request.auth.uid;
    }

    // Place reviews collection (imported from Google)
    match /placeReviews/{reviewId} {
      allow read: if true; // Public reviews

      // Allow create/update/delete if:
      // 1. User is the review owner (placeOwnerId field)
      // 2. User is admin
      // 3. User owns the place that this review belongs to
      allow create, update, delete: if isAuthenticated() && (
        resource.data.placeOwnerId == request.auth.uid ||
        isAdmin() ||
        // Check if user owns the place by looking up the place document
        (exists(/databases/$(database)/documents/places/$(resource.data.placeId)) &&
         (get(/databases/$(database)/documents/places/$(resource.data.placeId)).data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/places/$(resource.data.placeId)).data.claimedBy == request.auth.uid))
      );
    }

    // Reviews collection (V2.0 - Custom review forms)
    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if true; // Anyone can create reviews (even anonymous)
      allow update, delete: if isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid ||
        isAdmin()
      );
    }

    // Review form configurations (per professional)
    match /reviewFormConfigs/{configId} {
      allow read: if true; // Anyone can read form configs (needed for public review form)
      allow create, update, delete: if isAuthenticated() && (
        exists(/databases/$(database)/documents/professionals/$(configId)) &&
        get(/databases/$(database)/documents/professionals/$(configId)).data.userId == request.auth.uid
      );
    }

    // ============================================
    // PAYMENT SYSTEM RULES (EuPago Integration)
    // ============================================

    // Payments collection
    match /payments/{paymentId} {
      // Users can read their own payments, admins can read all
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Users can create payment records (initiated by Cloud Functions)
      allow create: if isAuthenticated();

      // Only Cloud Functions can update payments
      // (status changes, webhook updates, etc.)
      allow update: if false;

      // No one can delete payments
      allow delete: if false;
    }

    // Subscriptions collection
    match /subscriptions/{userId} {
      // Users can read their own subscription, admins can read all
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || isAdmin()
      );

      // Only Cloud Functions can write subscriptions
      // (created/updated by webhook after payment confirmation)
      allow write: if false;
    }

    // Pricing plans collection
    match /pricing/{planId} {
      // Anyone can read pricing (public)
      allow read: if true;

      // Only admins can modify pricing
      allow write: if isAdmin();
    }

    // Pricing FAQs collection
    match /pricing-faqs/{faqId} {
      // Anyone can read FAQs (public)
      allow read: if true;

      // Only admins can modify FAQs
      allow write: if isAdmin();
    }

    // Feature definitions collection
    match /featureDefinitions/{featureId} {
      // Anyone can read feature definitions (public)
      allow read: if true;

      // Only admins can modify feature definitions
      allow write: if isAdmin();
    }

    // Promo codes collection
    match /promoCodes/{codeId} {
      // Anyone can read promo codes (for validation)
      allow read: if true;

      // Only admins can create/modify promo codes
      allow write: if isAdmin();
    }

    // Promo code redemptions collection
    match /promoCodeRedemptions/{redemptionId} {
      // Users can read their own redemptions
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;

      // Only Cloud Functions can create redemptions
      allow create: if false;
      allow update, delete: if false;
    }

    // ============================================
    // END PAYMENT SYSTEM RULES
    // ============================================

    // Admins collection (legacy - users can check if they are admin)
    match /admins/{adminId} {
      // Users can read their own admin document (for legacy admin check)
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      // Only admins can write
      allow write: if isAdmin();
    }

    // Admin-only collections
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
